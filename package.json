{
  "name": "realtime-webrtc-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade backend WebRTC gateway for OpenAI Realtime",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx tsc -p tsconfig.json",
    "start": "node dist/index.js",
