    "generate:offer": "node scripts/generate-real-offer.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@roamhq/wrtc": "^0.9.1",
    "@stream-io/video-client": "^1.35.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.0",
    "multer": "^1.4.5-lts.2",
    "livekit-server-sdk": "^2.15.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "ws": "^8.18.3",
    "zod": "^3.24.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
